# ============================================================
# .env  —  环境变量配置（部署前必须修改）
# 将此文件复制为 .env 并填入真实值，不要提交到 Git！
# ============================================================

# MySQL root 密码（首次初始化后不应更改）
MYSQL_ROOT_PASSWORD=Root@2024!

# 应用数据库账号（与 schema.sql 创建的账号一致）
DB_USER=qc_user
DB_PASS=qc_pass_2024

# JWT 签名密钥（至少 32 位随机字符串，必须修改！）
JWT_SECRET=xnl-qc-jwt-secret-please-change-this-to-random-string-2024
